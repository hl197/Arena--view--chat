# ==========================================
# ArenaView 环境变量配置
# ==========================================

# === 加密主密钥（自动生成，首次启动时写入 .env）===
# 用于加/解密下方的 _ENC 格式 API Key。
# 不要手动填写，不要提交到 Git。
# ARENA_MASTER_KEY=<auto-generated>

# === JWT 签名密钥（自动生成）===
# ARENA_SECRET_KEY=<auto-generated>

# === 默认 LLM（必填，二选一）===
# 推荐：先用 CLI 工具加密，再填入加密后的值
#   python -m backend.scripts.encrypt_key --key sk-xxx --name DEEPSEEK
# DEEPSEEK_API_KEY_ENC=gAAAAAB...

# 或者直接填写明文（不推荐，仅用于快速测试）
# DEEPSEEK_API_KEY=sk-xxx

# === 用户可通过 Web 界面切换的 Provider ===
# 每个都可以用 encrypted 或 plaintext 方式配置
# OPENAI_API_KEY_ENC=...
# GEMINI_API_KEY_ENC=...
# GROQ_API_KEY_ENC=...

# === 数据库（可选，默认 SQLite）===
# DATABASE_URL=sqlite:///arena.db

# === 部署 ===
# DEBUG=true
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
